{
  "name": "@excitedjs/dreamux",
  "version": "0.9.8",
  "description": "Codex-host server — single-session MVP. One node process hosts N dispatchers, each binding 1 Feishu bot + 1 Codex thread.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/excitedjs/dreamux.git",
    "directory": "packages/dreamux"
  },
  "type": "module",
  "main": "./dist/server.js",
  "engines": {
    "node": ">=22.7"
  },
  "bin": {
    "dreamux": "./bin/dreamux",
    "tm": "./bin/tm"
  },
  "files": [
    "bin",
    "dist",
    "skills",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CHANGELOG.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@excitedjs/feishu-transport": "workspace:*",
    "@excitedjs/tm": "2.2.1",
    "smol-toml": "^1.6.1",
    "ws": "^8.18.0",
    "yargs": "^17.7.2",
    "@clack/prompts": "^1.5.0",
    "execa": "^9.6.1",
    "pino": "^9.5.0",
    "plist": "^5.0.0"
  },
  "devDependencies": {
    "@excitedjs/eslint-config": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "@types/yargs": "^17.0.35",
    "eslint": "^9.39.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
