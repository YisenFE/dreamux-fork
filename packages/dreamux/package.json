{
  "name": "@excitedjs/dreamux",
  "version": "0.1.2",
  "description": "Codex-host server — single-session MVP. One node process hosts N dispatchers, each binding 1 Feishu bot + 1 Codex thread.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/excitedjs/dreamux.git",
    "directory": "packages/dreamux"
  },
  "type": "module",
  "main": "./dist/server.js",
  "engines": {
    "node": ">=22.7"
  },
  "bin": {
    "dreamux": "./bin/dreamux"
  },
  "files": [
    "bin",
    "dist",
    "db",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@excitedjs/feishu-transport": "workspace:*",
    "better-sqlite3": "^11.5.0",
    "smol-toml": "^1.6.1",
    "ws": "^8.18.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "@types/yargs": "^17.0.35",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
