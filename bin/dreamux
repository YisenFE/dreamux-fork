#!/usr/bin/env bash
# Source-checkout convenience shim for the single @excitedjs/dreamux CLI.
# The published package installs only packages/dreamux/bin/dreamux.
set -eu

SOURCE="${BASH_SOURCE[0]}"
hop=0
while [ -L "$SOURCE" ]; do
  hop=$((hop + 1))
  if [ "$hop" -gt 40 ]; then
    echo "dreamux: too many symlink hops resolving $SOURCE" >&2
    exit 1
  fi
  TARGET="$(readlink "$SOURCE")"
  if [ "${TARGET:0:1}" = "/" ]; then
    SOURCE="$TARGET"
  else
    SOURCE="$(dirname -- "$SOURCE")/$TARGET"
  fi
done

ROOT="$(cd -- "$(dirname -- "$SOURCE")/.." &> /dev/null && pwd)"
exec "$ROOT/packages/dreamux/bin/dreamux" "$@"
